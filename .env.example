# DataPilot 环境变量模板
# 复制为 .env 并填入真实值；生产部署务必设置 JWT_SECRET 与 LLM_API_KEY

# ---- 运行模式 ----
# 生产环境设为 false；本地开发可设 true（启用 dev-admin 免密登录等便捷功能）
DEBUG=false
# 仅在 DEBUG=true 时可设 true，完全跳过密码校验（仅本地联调）
ALLOW_NO_PASSWORD_LOGIN=false

# ---- JWT 认证 ----
# 生产环境必须设置为强随机字符串（>=32 字符）；未设置或为默认值时生产模式拒绝启动
JWT_SECRET=please-change-this-to-a-strong-random-secret
JWT_TTL=3600

# ---- CORS 跨域 ----
# 逗号分隔的前端域名白名单；留空则允许所有源但不携带凭证
# CORS_ORIGINS=https://a.example.com,https://b.example.com

# ---- LLM 配置 ----
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=2000
# 自一致性采样次数与温度
CONSISTENCY_N=3
CONSISTENCY_TEMP=0.3
# 错误驱动重试的最大次数
MAX_RETRIES=2

# ---- 数据源 ----
# 默认 SQLite (Spider) 数据库目录
SQLITE_PATH=datasets/spider_databases/database
# MySQL（可选）
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=
# API 数据源（JSON 字符串，可选）
API_SOURCES=[]

# ---- 沙箱 ----
SANDBOX_ENABLED=true
SANDBOX_IMAGE=datapilot-sandbox:latest
SANDBOX_TIMEOUT=30
SANDBOX_MEMORY=256m
SANDBOX_CPU=0.5
